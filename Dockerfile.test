FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    wget curl ca-certificates gnupg unzip \
    --no-install-recommends

# Install Chrome
RUN wget -q -O /tmp/chrome.deb https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb && \
    apt-get install -y /tmp/chrome.deb --no-install-recommends && \
    rm /tmp/chrome.deb

# Install matching ChromeDriver
RUN CHROME_VERSION=$(google-chrome --version | grep -oP '\d+\.\d+\.\d+') && \
    wget -q -O /tmp/chromedriver.zip "https://storage.googleapis.com/chrome-for-testing-public/${CHROME_VERSION}.0/linux64/chromedriver-linux64.zip" && \
    unzip /tmp/chromedriver.zip -d /tmp/ && \
    mv /tmp/chromedriver-linux64/chromedriver /usr/bin/chromedriver && \
    chmod +x /usr/bin/chromedriver && \
    rm -rf /tmp/chromedriver*

COPY requirements.test.txt .
RUN pip install --no-cache-dir -r requirements.test.txt

WORKDIR /tests
COPY tests/ .
RUN mkdir -p /tests/results

CMD ["python", "-m", "pytest", "test_todo.py", "-v", "--tb=short", \
     "--junit-xml=/tests/results/test-results.xml"]